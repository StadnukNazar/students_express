<!--view table of students-->
<style>
    .upper{
        margin-top: 4vh;
        
    }
    .button_back{
        color:#18db69; 
        background-color:#778899;  
        border-radius: 24px; 
        font-family: Garamond; 
        font-weight: 600; 
        font-size: 24px; 
        width: 10vw; 
        margin-bottom: 5vh;
        position: relative;
        right: 10vw;
    }
    .body{
        background-image:  #bdc3c7;
  background: linear-gradient(
    to right,
    #5D4157,#A8CABA
  ); 
        height:100vh
    }
</style>
<body class="body">
<div class="upper">
    <a href="/">
    <button class="button_back">Назад</button>
    </a>
</div>
</body>      
<table>
    <thead>
    <tr>
        <th scope="col">ID</th>
        <th scope="col">Назва вправи</th>
        <th scope="col">Рівень складності</th>
        <th scope="col">Рівень підготовки</th>
        <th scope="col">Група мязів</th>
        <th scope="col">Кількість підходів</th>
    </tr>
    </thead>
    <tbody>
    {{#each exercise}}
        <tr>
            <th scope="row">{{this.id}}</th>
            <td>{{this.exercise_name}}</td>
            <td>{{this.difficult_level}}</td>
            <td>{{this.required_level}}</td>
            <td>{{this.muscle_name}}</td>
            <td>{{this.sets}}</td>
            <td>
                  <button style="background-color: #000; padding: 5px 10px;">
                      <a style="color:#fff; text-decoration: none;" href="/gym2/delete/{{this.id}}">DELETE</a>
                  </button>
            </td>
        </tr>
    {{/each}}
    </tbody>
</table>
  <p><a style="color:rgb(229, 102, 168)" href="/gym2/addExercise">Додати вправу</a></p>
